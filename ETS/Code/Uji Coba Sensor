#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <BH1750.h>
#include <DHT.h>

// --- Inisialisasi LCD & Sensor I2C ---
LiquidCrystal_I2C lcd(0x27, 16, 2); 
BH1750 lightMeter;

// --- Inisialisasi Sensor Suara ---
const int pinAnalog = 34;
const int pinDigital = 32;

// --- Inisialisasi DHT22 ---
#define DHTPIN 4        // Kabel DATA DHT dihubungkan ke Pin 4 ESP32
#define DHTTYPE DHT22   // Jenis sensor DHT 22
DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Serial.begin(115200);
  Wire.begin(); 

  // Setup Layar
  lcd.init();
  lcd.backlight();
  
  // Setup Sensor
  pinMode(pinDigital, INPUT);
  dht.begin();
  lightMeter.begin();

  lcd.setCursor(0, 0);
  lcd.print("Memulai Sistem..");
  delay(2000);
}

void loop() {
  // --- 1. MEMBACA SEMUA DATA SENSOR ---
  float lux = lightMeter.readLightLevel();
  int nilaiSuara = analogRead(pinAnalog);
  int statusDigital = digitalRead(pinDigital);
  
  // Membaca suhu (Celsius) dan kelembapan (%)
  float t = dht.readTemperature();
  float h = dht.readHumidity();

  // --- 2. CEK ERROR DHT22 ---
  if (isnan(t) || isnan(h)) {
    Serial.println("Gagal membaca data dari DHT22!");
  }

  // --- 3. MENAMPILKAN HALAMAN 1 (CAHAYA & SUARA) ---
  lcd.clear();
  // Baris Atas
  lcd.setCursor(0, 0);
  lcd.print("Cahaya: ");
  lcd.print((int)lux);
  lcd.print(" lx");
  // Baris Bawah
  lcd.setCursor(0, 1);
  if (statusDigital == HIGH) {
    lcd.print("Suara: BERISIK!");
  } else {
    lcd.print("Suara: ");
    lcd.print(nilaiSuara);
  }
  
  delay(3000); // Tahan Halaman 1 selama 3 detik

  // --- 4. MENAMPILKAN HALAMAN 2 (SUHU & KELEMBAPAN) ---
  lcd.clear();
  // Baris Atas
  lcd.setCursor(0, 0);
  lcd.print("Suhu: ");
  lcd.print(t, 1); // Tampilkan 1 angka di belakang koma
  lcd.print(" C");
  // Baris Bawah
  lcd.setCursor(0, 1);
  lcd.print("Lembap: ");
  lcd.print(h, 1);
  lcd.print(" %");
  
  delay(3000); // Tahan Halaman 2 selama 3 detik
}
